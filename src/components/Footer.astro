---
const { settings, navigation } = Astro.props;
type NavLink = { href: string; label: string };
const footerLinks = (navigation?.footerLinks || []) as NavLink[];
---
<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <a href="/" class="logo"><span>Swift</span><span class="logo-mark">7</span></a>
        <p class="muted" style="margin-top:18px;max-width:320px">{settings?.footerText || settings?.tagline}</p>
      </div>
      <div>
        <h3>Pages</h3>
        <div class="footer-links">
          {footerLinks.map((link) => <a href={link.href}>{link.label}</a>)}
        </div>
      </div>
      <div>
        <h3>Contact</h3>
        <div class="footer-links">
          <a href={`mailto:${settings?.email}`}>{settings?.email}</a>
          <a href={`tel:${settings?.phone}`}>{settings?.phone}</a>
          <a href="https://wa.me/447380218301">WhatsApp</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <span>{settings?.copyrightText || '© 2026 Swift7. All rights reserved.'}</span>
      <span>Designed and built by Swift7.</span>
    </div>
  </div>
</footer>
