---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCaseStudies, getNavigation, getSiteSettings } from '../../lib/sanity';

export async function getStaticPaths() {
  const studies = await getCaseStudies();
  return studies.map((study) => ({ params: { slug: study.slug }, props: { study } }));
}

const { study } = Astro.props;
const [settings, navigation] = await Promise.all([getSiteSettings(), getNavigation()]);
const imageUrl = (image: unknown) => (typeof image === 'string' ? image : (image as { url?: string })?.url);
---
<BaseLayout settings={settings} navigation={navigation} title={study.seo?.title || `${study.clientName} Case Study | Swift7`} description={study.seo?.description || study.summary} seo={study.seo}>
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <span class="eyebrow">{study.location} · {study.industry}</span>
        <h1>{study.clientName}</h1>
        <p class="lead">{study.summary}</p>
        <div class="hero-actions">
          <a class="btn" href="/portfolio">Back to portfolio</a>
          <a class="btn btn-outline" href="/#start">Start my website</a>
        </div>
      </div>
      {study.featuredImage && <img class="case-hero-image" src={imageUrl(study.featuredImage)} alt={`${study.clientName} website screenshot`} />}
    </div>
  </section>
  <section>
    <div class="container feature-grid">
      <article class="card">
        <span class="tag">Challenge</span>
        <p>{study.challenge}</p>
      </article>
      <article class="card">
        <span class="tag">Solution</span>
        <p>{study.solution}</p>
      </article>
      <article class="card">
        <span class="tag">Result</span>
        <p>{study.results}</p>
      </article>
    </div>
  </section>
</BaseLayout>
